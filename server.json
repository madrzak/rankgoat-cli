{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-07-09/server.schema.json",
  "name": "io.github.madrzak/rankgoat",
  "description": "SEO for AI agents: plan content, publish posts, earn dofollow backlinks, track Domain Rating.",
  "repository": {
    "url": "https://github.com/madrzak/rankgoat-cli",
    "source": "github"
  },
  "version": "0.5.1",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "rankgoat",
      "version": "0.5.1",
      "transport": { "type": "stdio" },
      "runtimeHint": "npx",
      "runtimeArguments": [
        { "type": "positional", "value": "-y", "isRequired": true },
        { "type": "positional", "value": "rankgoat", "isRequired": true },
        { "type": "positional", "value": "mcp", "isRequired": true }
      ],
      "environmentVariables": [
        {
          "name": "RANKGOAT_API_KEY",
          "description": "API key from rankgoat.app Settings > API keys",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ]
}
